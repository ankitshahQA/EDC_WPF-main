<UserControl x:Class="EDC.Wpf.Views.TestsToRunPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EDC.Wpf.ViewModels"
             d:DataContext="{d:DesignInstance vm:MainViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource WindowBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel>

            <Border Style="{DynamicResource CardBorder}">
                <StackPanel>
                    <CheckBox Style="{DynamicResource ProCheckBox}"
                              FontSize="{StaticResource FontSize.SubTitle}" FontWeight="SemiBold"
                              Content="Run All Tests"
                              ToolTip="Select / clear every test below."
                              IsChecked="{Binding Config.RunAllTest}"/>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="24,4,0,0">
                        <Run Text="{Binding TestSelection.SelectedTestCount, Mode=OneWay}"/>
                        <Run Text="of"/>
                        <Run Text="{Binding TestSelection.TotalTestCount, Mode=OneWay}"/>
                        <Run Text="tests selected"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{DynamicResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Server Tests" Style="{DynamicResource SectionHeaderText}" Margin="0,0,0,4"/>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding TestSelection.ServerTestCount, StringFormat='{}{0} of 3 selected'}"
                               Margin="0,0,0,8"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Login to Server Admin"
                              ToolTip="Sign in to each server's /admin endpoint and verify the dashboard loads."
                              IsChecked="{Binding Config.LoginServer}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Login to Server Manager"
                              ToolTip="Sign in to each server's /manager endpoint."
                              IsChecked="{Binding Config.LoginManager}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Validate Data Stores"
                              ToolTip="Check registered relational / tile-cache / object data stores (not applicable on Kubernetes)."
                              IsChecked="{Binding Config.ValidateDataStores}"
                              IsEnabled="{Binding TestSelection.IsKubernetesIncompatibleEnabled}"/>
                </StackPanel>
            </Border>

            <Border Style="{DynamicResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Portal Tests" Style="{DynamicResource SectionHeaderText}" Margin="0,0,0,4"/>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding TestSelection.PortalTestCount, StringFormat='{}{0} of 12 selected'}"
                               Margin="0,0,0,8"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Login to Portal"
                              ToolTip="Sign in to Portal home page with the credentials above. Auto-selected whenever a portal test is ticked."
                              IsChecked="{Binding Config.LoginPortal}"
                              IsEnabled="{Binding TestSelection.IsLoginPortalEnabled}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Create Feature Layer"
                              ToolTip="Publish a hosted feature layer from a CSV/SHP sample."
                              IsChecked="{Binding Config.CreateFeatureLayer}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Create Tile Layer"
                              ToolTip="Publish a hosted tile layer from a sample VTPK."
                              IsChecked="{Binding Config.CreateTileLayer}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Check Scene Layer functionality (11.1 and above)"
                              ToolTip="Publish and view a hosted scene layer from a sample SLPK."
                              IsChecked="{Binding Config.CreateSceneLayer}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Create Web Map"
                              ToolTip="Author and save a web map in Map Viewer."
                              IsChecked="{Binding Config.CreateMap}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Create Dashboard (12.0 and above)"
                              ToolTip="Author and save a Dashboards item."
                              IsChecked="{Binding Config.CreateDashboard}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Create Story Map (12.0 and above)"
                              ToolTip="Author and save a StoryMaps item."
                              IsChecked="{Binding Config.CreateStoryMap}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Create Experience Builder App (12.0 and above)"
                              ToolTip="Launch ArcGIS Experience Builder and save a new experience. Mutually exclusive with Web AppBuilder."
                              IsChecked="{Binding Config.CreateExperienceBuilderApp}"
                              IsEnabled="{Binding TestSelection.IsExperienceBuilderEnabled}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Create Web AppBuilder App (11.5 and below)"
                              ToolTip="Launch Web AppBuilder and save a new app (legacy installs only). Mutually exclusive with Experience Builder."
                              IsChecked="{Binding Config.CreateWebAppBuilder}"
                              IsEnabled="{Binding TestSelection.IsWebAppBuilderEnabled}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Create Group / Member and share content"
                              ToolTip="Create a group, add a member, and validate sharing permissions."
                              IsChecked="{Binding Config.CreateMember}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Check Organization functionality"
                              ToolTip="Validate organization settings, roles, and licensing in Portal."
                              IsChecked="{Binding Config.ValidateOrganization}"/>
                    <CheckBox Style="{DynamicResource ProCheckBox}" Content="Validate Server Role (11.3 and above)"
                              ToolTip="Confirm each federated server reports the expected role (not applicable on Kubernetes)."
                              IsChecked="{Binding Config.ValidateServerRole}"
                              IsEnabled="{Binding TestSelection.IsKubernetesIncompatibleEnabled}"/>
                   
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
