<UserControl x:Class="EDC.Wpf.Views.ResultsLogPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EDC.Wpf.ViewModels"
             xmlns:logging="clr-namespace:EDC.Core.Logging;assembly=EDC.Core"
             d:DataContext="{d:DesignInstance vm:MainViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource WindowBackgroundBrush}">

    <UserControl.Resources>
        <!-- Theme-aware log message foreground. The previous LogLevelToBrushConverter
             pinned brush references at convert time, so log lines kept the old
             theme's foreground after a Dark<->Light swap. Using DynamicResource
             via DataTriggers makes the foreground re-resolve on theme change. -->
        <Style x:Key="LogMessageText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Pass">
                    <Setter Property="Foreground" Value="{DynamicResource StatusPassTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Fail">
                    <Setter Property="Foreground" Value="{DynamicResource StatusFailTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Error">
                    <Setter Property="Foreground" Value="{DynamicResource StatusFailTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Skip">
                    <Setter Property="Foreground" Value="{DynamicResource StatusSkipTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Warn">
                    <Setter Property="Foreground" Value="{DynamicResource StatusSkipTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Heading">
                    <Setter Property="Foreground" Value="{DynamicResource BrandBlueBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Step">
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LogGlyphText" TargetType="TextBlock" BasedOn="{StaticResource LogMessageText}">
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- Theme-aware Path Fill for the per-row glyph (DataContext = LogEntry).
             DynamicResource in DataTrigger setters re-resolves on Dark<->Light swap. -->
        <Style x:Key="LogEntryGlyphPath" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Pass">
                    <Setter Property="Fill" Value="{DynamicResource StatusPassTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Fail">
                    <Setter Property="Fill" Value="{DynamicResource StatusFailTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Error">
                    <Setter Property="Fill" Value="{DynamicResource StatusFailTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Skip">
                    <Setter Property="Fill" Value="{DynamicResource StatusSkipTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Warn">
                    <Setter Property="Fill" Value="{DynamicResource StatusSkipTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Heading">
                    <Setter Property="Fill" Value="{DynamicResource BrandBlueBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Step">
                    <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Theme-aware Path Fill for the group-header outcome glyph (DataContext = TestCaseLogGroup). -->
        <Style x:Key="LogGroupGlyphPath" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Outcome}" Value="Pass">
                    <Setter Property="Fill" Value="{DynamicResource StatusPassTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Fail">
                    <Setter Property="Fill" Value="{DynamicResource StatusFailTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Error">
                    <Setter Property="Fill" Value="{DynamicResource StatusFailTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Skip">
                    <Setter Property="Fill" Value="{DynamicResource StatusSkipTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Warn">
                    <Setter Property="Fill" Value="{DynamicResource StatusSkipTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Theme-aware TextBlock Foreground for the group-header outcome label (DataContext = TestCaseLogGroup). -->
        <Style x:Key="LogGroupOutcomeText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Outcome}" Value="Pass">
                    <Setter Property="Foreground" Value="{DynamicResource StatusPassTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Fail">
                    <Setter Property="Foreground" Value="{DynamicResource StatusFailTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Error">
                    <Setter Property="Foreground" Value="{DynamicResource StatusFailTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Skip">
                    <Setter Property="Foreground" Value="{DynamicResource StatusSkipTextBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Warn">
                    <Setter Property="Foreground" Value="{DynamicResource StatusSkipTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Outcome-tinted pill background for the per-test-case header (DataContext = TestCaseLogGroup). -->
        <Style x:Key="TestCaseStatusPillBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Outcome}" Value="Pass">
                    <Setter Property="Background" Value="{DynamicResource StatusPassBgBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Fail">
                    <Setter Property="Background" Value="{DynamicResource StatusFailBgBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Error">
                    <Setter Property="Background" Value="{DynamicResource StatusFailBgBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Skip">
                    <Setter Property="Background" Value="{DynamicResource StatusSkipBgBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Outcome}" Value="Warn">
                    <Setter Property="Background" Value="{DynamicResource StatusSkipBgBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Flat, chrome-free ToggleButton template for the modern test-case row.
             Replaces the default Expander look so each test case reads as a single
             row with hover affordance + an optional rotating chevron. -->
        <Style x:Key="TestCaseRowToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource HoverOverlayBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Disclosure chevron that rotates 90° when its TestCaseLogGroup IsExpanded. -->
        <Style x:Key="TestCaseChevronPath" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <RotateTransform Angle="90" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel>

        <!-- Summary strip -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{DynamicResource ProButton}" Padding="0" BorderThickness="0" Background="Transparent"
                            Command="{Binding ResultsLog.FilterAllCommand}" Cursor="Hand" Margin="0,0,16,0"
                            ToolTip="Show all test cases. Clears any active filter.">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Total: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding ResultsLog.Total}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource ProButton}" Padding="0" BorderThickness="0" Background="Transparent"
                            Command="{Binding ResultsLog.FilterPassedCommand}" Cursor="Hand" Margin="0,0,8,0"
                            ToolTip="Show only passed test cases.">
                        <Border Background="{DynamicResource StatusPassBgBrush}" CornerRadius="10" Padding="8,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource Calcite.Geom.Check}" Stretch="Uniform" Width="12" Height="12"
                                      Fill="{DynamicResource StatusPassTextBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding ResultsLog.Passed}" Foreground="{DynamicResource StatusPassTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text=" Passed" Foreground="{DynamicResource StatusPassTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </Button>
                    <Button Style="{DynamicResource ProButton}" Padding="0" BorderThickness="0" Background="Transparent"
                            Command="{Binding ResultsLog.FilterFailedCommand}" Cursor="Hand" Margin="0,0,8,0"
                            ToolTip="Show only failed test cases.">
                        <Border Background="{DynamicResource StatusFailBgBrush}" CornerRadius="10" Padding="8,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource Calcite.Geom.X}" Stretch="Uniform" Width="12" Height="12"
                                      Fill="{DynamicResource StatusFailTextBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding ResultsLog.Failed}" Foreground="{DynamicResource StatusFailTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text=" Failed" Foreground="{DynamicResource StatusFailTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </Button>
                    <Button Style="{DynamicResource ProButton}" Padding="0" BorderThickness="0" Background="Transparent"
                            Command="{Binding ResultsLog.FilterSkippedCommand}" Cursor="Hand"
                            ToolTip="Show only skipped test cases. Click Total to clear the filter.">
                        <Border Background="{DynamicResource StatusSkipBgBrush}" CornerRadius="10" Padding="8,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource Calcite.Geom.Reset}" Stretch="Uniform" Width="12" Height="12"
                                      Fill="{DynamicResource StatusSkipTextBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding ResultsLog.Skipped}" Foreground="{DynamicResource StatusSkipTextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text=" Skipped" Foreground="{DynamicResource StatusSkipTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Test-case sections: one collapsible expander per test case -->
        <ScrollViewer Background="{DynamicResource WindowBackgroundBrush}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="LogList"
                          ItemsSource="{Binding ResultsLog.FilteredGroups}"
                          Background="{DynamicResource WindowBackgroundBrush}">
                <ItemsControl.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Copy all" Click="CopyAll_OnClick"
                                  ToolTip="Copy every log entry to the clipboard."/>
                        <MenuItem Header="Clear log"
                                  Command="{Binding ResultsLog.ClearLogCommand}"
                                  ToolTip="Empty the pane (does not delete files on disk). Disabled while a run is in progress."/>
                    </ContextMenu>
                </ItemsControl.ContextMenu>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type logging:TestCaseLogGroup}">
                        <!-- Modern test-runner row:
                                [chevron] [status pill]   Test name             Duration
                                          (expanded body: indented per-line glyph + monospace message)
                             No Expander chrome - the whole header row is a flat ToggleButton bound
                             to IsExpanded; the body collapses with BoolToVisibilityConverter. -->
                        <Border Margin="8,4,8,0"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                              Style="{StaticResource TestCaseRowToggle}"
                                              Padding="12,9">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Disclosure chevron (rotates 90° when expanded) -->
                                        <Path Grid.Column="0"
                                              Data="{StaticResource Calcite.Geom.ChevronRight}"
                                              Style="{StaticResource TestCaseChevronPath}"
                                              Stretch="Uniform" Width="9" Height="9"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>

                                        <!-- Status pill: outcome-tinted background + icon + label -->
                                        <Border Grid.Column="1"
                                                Style="{StaticResource TestCaseStatusPillBorder}"
                                                Margin="0,0,12,0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Path Data="{Binding Outcome, Converter={StaticResource LogLevelToCalciteGeometryConverter}}"
                                                      Stretch="Uniform" Width="11" Height="11"
                                                      Style="{StaticResource LogGroupGlyphPath}"
                                                      VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding OutcomeText}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Style="{StaticResource LogGroupOutcomeText}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Test case name -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Duration -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding DurationText}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   ToolTip="Elapsed time for this test case"/>
                                    </Grid>
                                </ToggleButton>

                                <!-- Body: per-line glyph + monospace message, indented under the row -->
                                <ItemsControl ItemsSource="{Binding Entries}"
                                              Margin="36,0,12,10"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type logging:LogEntry}">
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="0"
                                                      Data="{Binding Level, Converter={StaticResource LogLevelToCalciteGeometryConverter}}"
                                                      Stretch="Uniform" Width="12" Height="12"
                                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                                      Style="{StaticResource LogEntryGlyphPath}"/>
                                                <TextBox Grid.Column="1" FontFamily="Consolas" FontSize="12"
                                                         TextWrapping="Wrap"
                                                         Text="{Binding Message, Mode=OneWay}"
                                                         IsReadOnly="True"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         Padding="0"
                                                         Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                                         ContextMenu="{x:Null}"
                                                         ToolTip="Select text and press Ctrl+C to copy"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
