<fluent:RibbonWindow x:Class="EDC.Wpf.Views.MainWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:fluent="urn:fluent-ribbon"
                     xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
                     xmlns:avalonDockControls="clr-namespace:AvalonDock.Controls;assembly=AvalonDock"
                     xmlns:vm="clr-namespace:EDC.Wpf.ViewModels"
                     xmlns:views="clr-namespace:EDC.Wpf.Views"
                     xmlns:conv="clr-namespace:EDC.Wpf.Converters"
                     Title="Enterprise Deployment Check"
                     TitleBarHeight="34"
                     Icon="pack://application:,,,/Assets/esri_logo.png"
                     Template="{StaticResource Fluent.Ribbon.Templates.RibbonWindow.BigIcon}"
                     Width="1400" Height="900"
                     MinWidth="1000" MinHeight="650"
                     WindowStartupLocation="CenterScreen"
                     Background="{DynamicResource WindowBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}">

    <fluent:RibbonWindow.DataContext>
        <vm:MainViewModel/>
    </fluent:RibbonWindow.DataContext>

    <Grid>
        <DockPanel LastChildFill="True">

        <!-- ═══════════════════ Ribbon (ArcGIS Pro-style task tabs) ═══════════════════ -->
        <fluent:Ribbon DockPanel.Dock="Top" SelectedTabIndex="0">

            <!-- Project backstage: like ArcGIS Pro's left-rail "Project" page.
                 Each item is a verb the user actually performs against the
                 currently-loaded EDC configuration. -->
            <fluent:Ribbon.Menu>
                <fluent:Backstage Header="Project">
                    <fluent:BackstageTabControl>

                        <fluent:BackstageTabItem Header="New">
                            <StackPanel Margin="40,30" MaxWidth="640">
                                <TextBlock Text="New configuration" FontSize="22" FontWeight="Light"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Margin="0,8,0,20" TextWrapping="Wrap" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="Discards the current portal credentials, server slots and test selections so you can configure a fresh deployment check from scratch. The on-disk file Input\config.properties is rewritten when you save."/>
                                <Button Style="{DynamicResource ProButton}" Content="Reset to defaults"
                                        HorizontalAlignment="Left" Padding="18,8"
                                        ToolTip="Clear portal credentials, servers and test selections."
                                        Command="{Binding NewConfigCommand}"/>
                            </StackPanel>
                        </fluent:BackstageTabItem>

                        <fluent:BackstageTabItem Header="Open">
                            <StackPanel Margin="40,30" MaxWidth="640">
                                <TextBlock Text="Reload configuration" FontSize="22" FontWeight="Light"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Margin="0,8,0,20" TextWrapping="Wrap" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="Re-reads Input\config.properties from disk, discarding any unsaved edits in the panes."/>
                                <Button Style="{DynamicResource ProButton}" Content="Reload from disk"
                                        HorizontalAlignment="Left" Padding="18,8"
                                        ToolTip="Re-read Input\config.properties, discarding unsaved edits."
                                        Command="{Binding ReloadConfigCommand}"/>
                            </StackPanel>
                        </fluent:BackstageTabItem>

                        <fluent:BackstageTabItem Header="Save">
                            <StackPanel Margin="40,30" MaxWidth="640">
                                <TextBlock Text="Save configuration" FontSize="22" FontWeight="Light"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Margin="0,8,0,20" TextWrapping="Wrap" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="Writes the current portal, servers and test selections to Input\config.properties next to the executable."/>
                                <Button Style="{DynamicResource ProButton}" Content="Save now"
                                        HorizontalAlignment="Left" Padding="18,8"
                                        ToolTip="Write the current values to Input\config.properties."
                                        Command="{Binding SaveConfigCommand}"/>
                            </StackPanel>
                        </fluent:BackstageTabItem>

                        <fluent:BackstageTabItem Header="Reports">
                            <Grid Margin="40,30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Reports" FontSize="22" FontWeight="Light"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Row="1" Margin="0,8,0,4" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                           Text="Every run writes an HTML report into EnterpriseDeploymentCheckResults. Double-click an entry to open it; right-click for more options."/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,8">
                                    <Button Style="{DynamicResource ProButton}" Content="Refresh" Padding="14,5" Margin="0,0,8,0"
                                            ToolTip="Re-scan the reports folder."
                                            Command="{Binding Reports.RefreshCommand}"/>
                                    <Button Style="{DynamicResource ProButton}" Content="Open in Explorer" Padding="14,5" Margin="0,0,8,0"
                                            ToolTip="Open the EnterpriseDeploymentCheckResults folder in Windows Explorer."
                                            Command="{Binding Reports.OpenRootCommand}"/>
                                    <Button Style="{DynamicResource ProButton}" Content="Open latest report" Padding="14,5"
                                            ToolTip="Open the most recent HTML report."
                                            Command="{Binding OpenReportCommand}"/>
                                    <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="{Binding Reports.Status}"/>
                                </StackPanel>

                                <Border Grid.Row="3"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                    <ListView ItemsSource="{Binding Reports.Items}"
                                              SelectedItem="{Binding Reports.Selected}"
                                              Background="Transparent" BorderThickness="0"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <ListView.InputBindings>
                                            <KeyBinding Key="Enter"
                                                        Command="{Binding Reports.OpenItemCommand}"
                                                        CommandParameter="{Binding Reports.Selected}"/>
                                        </ListView.InputBindings>
                                        <ListView.Resources>
                                            <!-- Make hover/selected rows legible in BOTH dark and light themes.
                                                 The system default uses Aero white-on-pale-blue which disappears in dark mode. -->
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                             Color="#403E8FFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                                             Color="#FFFFFFFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                                             Color="#283E8FFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                                             Color="#FFF2F2F2"/>
                                        </ListView.Resources>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="4,3"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListViewItem">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="Transparent"
                                                                    BorderThickness="0"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    SnapsToDevicePixels="True">
                                                                <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                                                      Columns="{TemplateBinding GridView.ColumnCollection}"
                                                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#403E8FFF"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <EventSetter Event="MouseDoubleClick" Handler="ReportItem_OnDoubleClick"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open"
                                                          Command="{Binding PlacementTarget.DataContext.Reports.OpenItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Reports.Selected, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="Show in Explorer"
                                                          Command="{Binding PlacementTarget.DataContext.Reports.RevealInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.Reports.Selected, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <Separator/>
                                                <MenuItem Header="Refresh list"
                                                          Command="{Binding PlacementTarget.DataContext.Reports.RefreshCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </ListView.ContextMenu>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Name" Width="280">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                           Margin="0,0,8,0"
                                                                           Foreground="{DynamicResource AccentBrush}"
                                                                           Text="&#xE8A5;"/>
                                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Date modified" Width="160"
                                                                DisplayMemberBinding="{Binding Modified, StringFormat=yyyy-MM-dd HH:mm}"/>
                                                <GridViewColumn Header="Type" Width="110"
                                                                DisplayMemberBinding="{Binding Kind}"/>
                                                <GridViewColumn Header="Size" Width="90"
                                                                DisplayMemberBinding="{Binding SizeDisplay}"/>
                                                <GridViewColumn Header="Folder" Width="240"
                                                                DisplayMemberBinding="{Binding Folder}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Border>

                                <TextBlock Grid.Row="4" Margin="0,8,0,0" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="Folder:"/>
                                    <Run Text="{Binding Reports.RootPath, Mode=OneWay}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </Grid>
                        </fluent:BackstageTabItem>

                        <fluent:BackstageTabItem Header="About">
                            <StackPanel Margin="40,30" MaxWidth="720">
                                <TextBlock Text="About Enterprise Deployment Check" FontSize="22" FontWeight="Light"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Margin="0,12,0,0" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Text="WPF front-end (version 1.0.0) for the Selenium/TestNG validation engine. Supports ArcGIS Enterprise on Windows and Kubernetes."/>
                                <Border Margin="0,18,0,0" Padding="14"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}">
                                            <Run Text="Java runtime:" FontWeight="SemiBold"/>
                                            <LineBreak/>
                                            <Run Text="{Binding JavaPath, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Button Style="{DynamicResource ProButton}" Content="Open Help Document"
                                        HorizontalAlignment="Left" Padding="18,8" Margin="0,16,0,0"
                                        ToolTip="Open the Enterprise Deployment Check PDF help document."
                                        Command="{Binding OpenHelpDocCommand}"/>
                            </StackPanel>
                        </fluent:BackstageTabItem>

                        <!-- Exit row at the bottom of the left rail (like Word's Close). -->
                        <fluent:Button Header="Exit" Click="ExitButton_OnClick"
                                       ToolTip="Close the application."/>
                    </fluent:BackstageTabControl>
                </fluent:Backstage>
            </fluent:Ribbon.Menu>

            <!-- ═══════════ Run tab — the primary workflow ═══════════ -->
            <fluent:RibbonTabItem Header="Run">

                <fluent:RibbonGroupBox Header="Configuration">
                    <fluent:Button Header="Save" Size="Middle" Command="{Binding SaveConfigCommand}"
                                   Icon="{StaticResource Calcite.Save}"
                                   ToolTip="Write current values to Input\config.properties."/>
                    <fluent:Button Header="Reload" Size="Middle" Command="{Binding ReloadConfigCommand}"
                                   Icon="{StaticResource Calcite.Refresh}"
                                   ToolTip="Discard edits and re-read Input\config.properties."/>
                    <fluent:Button Header="New" Size="Middle" Command="{Binding NewConfigCommand}"
                                   Icon="{StaticResource Calcite.File}"
                                   ToolTip="Reset all fields to defaults."/>
                </fluent:RibbonGroupBox>

                <fluent:RibbonGroupBox Header="Execution">
                    <fluent:Button Header="Run Tests" Size="Large"
                                   LargeIcon="{StaticResource Calcite.Play.Large}"
                                   Icon="{StaticResource Calcite.Play}"
                                   Command="{Binding RunTestsCommand}"
                                   IsEnabled="{Binding CanRun}"
                                   ToolTip="Save the configuration and start the Java engine."/>
                    <fluent:Button Header="Stop" Size="Large"
                                   LargeIcon="{StaticResource Calcite.X.Large}"
                                   Icon="{StaticResource Calcite.X}"
                                   Command="{Binding StopTestsCommand}"
                                   IsEnabled="{Binding CanStop}"
                                   ToolTip="Terminate the engine and any browsers it has launched."/>
                </fluent:RibbonGroupBox>

                <fluent:RibbonGroupBox Header="Output">
                    <fluent:Button Header="Open Report" Size="Large" Command="{Binding OpenReportCommand}"
                                   LargeIcon="{StaticResource Calcite.FileReport.Large}"
                                   Icon="{StaticResource Calcite.FileReport}"
                                   ToolTip="Open the most recent HTML report in your browser."/>
                    <fluent:Button Header="Results Folder" Size="Middle" Command="{Binding OpenResultsFolderCommand}"
                                   Icon="{StaticResource Calcite.FolderOpen}"
                                   ToolTip="Open the EnterpriseDeploymentCheckResults folder in Explorer."/>
                    <fluent:Button Header="Clear Log" Size="Middle" Command="{Binding ResultsLog.ClearLogCommand}"
                                   Icon="{StaticResource Calcite.Trash}"
                                   ToolTip="Empty the Results Log pane (does not delete files on disk)."/>
                </fluent:RibbonGroupBox>
            </fluent:RibbonTabItem>

            <!-- ═══════════ Tests tab — selection summary ═══════════ -->
            <fluent:RibbonTabItem Header="Tests">
                <fluent:RibbonGroupBox Header="Selection">
                    <fluent:CheckBox Header="Run all tests"
                                     ToolTip="Tick to enable every test below; untick to clear all selections."
                                     IsChecked="{Binding Config.RunAllTest}"/>
                </fluent:RibbonGroupBox>
                <fluent:RibbonGroupBox Header="Deployment">
                    <fluent:CheckBox Header="Kubernetes (disables data-store / server-role tests)"
                                     ToolTip="Tick when validating ArcGIS Enterprise on Kubernetes."
                                     IsChecked="{Binding Config.Kubernetes}"/>
                </fluent:RibbonGroupBox>
                <fluent:RibbonGroupBox Header="Summary">
                    <StackPanel Margin="8,4" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold">
                            <Run Text="{Binding TestSelection.SelectedTestCount, Mode=OneWay}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TestSelection.TotalTestCount, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="tests selected" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </fluent:RibbonGroupBox>
            </fluent:RibbonTabItem>

            <!-- ═══════════ View tab ═══════════ -->
            <fluent:RibbonTabItem Header="View">
                <fluent:RibbonGroupBox Header="Theme">
                    <fluent:Button Header="Toggle Theme" Size="Middle" Command="{Binding ToggleThemeCommand}"
                                   Icon="{StaticResource Calcite.Moon}"
                                   ToolTip="Switch between Dark and Light surface palettes."/>
                </fluent:RibbonGroupBox>
            </fluent:RibbonTabItem>

            <!-- ═══════════ Help tab ═══════════ -->
            <fluent:RibbonTabItem Header="Help">
                <fluent:RibbonGroupBox Header="Info">
                    <fluent:Button Header="About" Size="Large" Click="AboutButton_OnClick"
                                   MinWidth="96"
                                   LargeIcon="{StaticResource Calcite.Information.Large}"
                                   Icon="{StaticResource Calcite.Information}"
                                   ToolTip="Show version, Java runtime path and engine JAR location."/>
                    <fluent:Button Header="Help Document" Size="Large"
                                   MinWidth="96"
                                   LargeIcon="{StaticResource Calcite.FileReport.Large}"
                                   Icon="{StaticResource Calcite.FileReport}"
                                   Command="{Binding OpenHelpDocCommand}"
                                   ToolTip="Open the Enterprise Deployment Check PDF help document."/>
                </fluent:RibbonGroupBox>
            </fluent:RibbonTabItem>
        </fluent:Ribbon>

        <!-- ═══════════════════ Status bar ═══════════════════ -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBrush}" Height="26">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ResultsLog.StatusText}" Foreground="White" Margin="14,0" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Width="160" Height="10" Margin="8,0"
                             Minimum="0" Maximum="100"
                             Value="{Binding ResultsLog.ProgressValue, Mode=OneWay}"
                             IsIndeterminate="{Binding ResultsLog.IsIndeterminate}"
                             Visibility="{Binding ResultsLog.IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding ResultsLog.ElapsedText}" Foreground="White"
                           Margin="14,0" VerticalAlignment="Center" FontFamily="Consolas"/>
            </Grid>
        </Border>

        <!-- ═══════════════════ Workspace ═══════════════════ -->
        <!-- Left: TabControl with "Input Parameters" / "Tests to Run".
             Right: single-tab TabControl with "Results Log" using the same tab
             styling so the headers look identical across both panes. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="380"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="380"/>
            </Grid.ColumnDefinitions>
            <Grid.Resources>
                <!-- Ribbon-style tab headers: flat, no chrome, brand-blue underline on the
                     selected tab. Shared by both the left ("Input Parameters" /
                     "Tests to Run") and right ("Results Log") TabControls so the headers
                     look identical across the workspace. -->
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabItem}">
                                <Grid x:Name="Root" Background="{TemplateBinding Background}">
                                    <ContentPresenter x:Name="ContentSite"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"
                                                      RecognizesAccessKey="True"/>
                                    <Border x:Name="Underline" Height="3"
                                            VerticalAlignment="Bottom"
                                            Background="{DynamicResource BrandBlueBrush}"
                                            Visibility="Collapsed"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Underline" Property="Visibility" Value="Visible"/>
                                        <Setter Property="Foreground" Value="{DynamicResource BrandBlueBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="{x:Type TabControl}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabControl}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="0,0,0,1"
                                            Background="{DynamicResource WindowBackgroundBrush}">
                                        <TabPanel IsItemsHost="True" Background="Transparent" Margin="0"/>
                                    </Border>
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter ContentSource="SelectedContent"/>
                                    </Border>
                                </DockPanel>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <TabControl Grid.Column="0" TabStripPlacement="Top"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        BorderThickness="0"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        Padding="0">
                <TabItem Header="Input Parameters">
                    <views:InputParametersPane DataContext="{Binding}"/>
                </TabItem>
                <TabItem Header="Tests to Run">
                    <views:TestsToRunPane DataContext="{Binding}"/>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderSubtleBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right pane: single-tab TabControl so the "Results Log" header gets the
                 same flat, brand-blue-underline styling as the "Input Parameters" /
                 "Tests to Run" tabs on the left (style is inherited from the left
                 TabControl resources above via implicit type-targeted styles). -->
            <TabControl Grid.Column="2" TabStripPlacement="Top"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        BorderThickness="0"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        Padding="0">
                <TabItem Header="Results Log">
                    <views:ResultsLogPane DataContext="{Binding}"/>
                </TabItem>
            </TabControl>
        </Grid>
        </DockPanel>

        <!-- ═══════════════════ Toast overlay (top-right, non-modal) ═══════════════════ -->
        <ItemsControl ItemsSource="{Binding Toasts.Toasts}"
                      HorizontalAlignment="Right" VerticalAlignment="Top"
                      Margin="0,12,16,0" Width="360"
                      IsHitTestVisible="True" Panel.ZIndex="1000">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8" CornerRadius="4" Padding="12,10"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.35" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       VerticalAlignment="Top" Margin="0,1,10,0"
                                       Text="{Binding Glyph}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource BrandBlueBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Severity}" Value="Success">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusPassTextBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusSkipTextBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                <Setter Property="Foreground" Value="{DynamicResource StatusFailTextBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Margin="0,2,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="✕" Width="22" Height="22"
                                    Margin="8,-2,-4,0" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    ToolTip="Dismiss notification"
                                    Command="{Binding DataContext.Toasts.DismissCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</fluent:RibbonWindow>
