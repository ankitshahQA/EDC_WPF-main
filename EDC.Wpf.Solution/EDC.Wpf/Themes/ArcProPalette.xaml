<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         ArcGIS Pro / Esri Calcite palette (theme-neutral colors)
         These are referenced by both Dark.xaml and Light.xaml.
         ============================================================ -->

    <!-- Brand (Esri Calcite primary #007AC2 + darker variant #005B94) -->
    <Color x:Key="Calcite.Brand.Blue">#FF007AC2</Color>
    <Color x:Key="Calcite.Brand.BlueHover">#FF006BAB</Color>
    <Color x:Key="Calcite.Brand.BluePressed">#FF005B94</Color>
    <SolidColorBrush x:Key="BrandBlueBrush" Color="{StaticResource Calcite.Brand.Blue}" />
    <SolidColorBrush x:Key="BrandBlueHoverBrush" Color="{StaticResource Calcite.Brand.BlueHover}" />
    <SolidColorBrush x:Key="BrandBluePressedBrush" Color="{StaticResource Calcite.Brand.BluePressed}" />

    <!-- Semantic state colors -->
    <Color x:Key="Calcite.Success">#FF35AC46</Color>
    <Color x:Key="Calcite.Warning">#FFEDD317</Color>
    <Color x:Key="Calcite.Danger">#FFD83020</Color>
    <Color x:Key="Calcite.Info">#FF007AC2</Color>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Calcite.Success}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Calcite.Warning}" />
    <SolidColorBrush x:Key="DangerBrush"  Color="{StaticResource Calcite.Danger}" />
    <SolidColorBrush x:Key="InfoBrush"    Color="{StaticResource Calcite.Info}" />

    <!-- Type system -->
    <FontFamily x:Key="UiFontFamily">Segoe UI, Avenir Next LT Pro</FontFamily>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize.Caption">11</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize.Body">13</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize.SubTitle">15</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSize.Title">18</System:Double>

</ResourceDictionary>
