<!--
    Esri Calcite UI Icons (16px) - WPF resources for Fluent.Ribbon buttons.

    Source:  https://github.com/Esri/calcite-ui-icons
    Browse:  https://developers.arcgis.com/calcite-design-system/icons/

    Each Geometry is the raw "d=" attribute from <icon>-16.svg (viewBox 0 0 16 16).
    Two render variants per icon:
        Calcite.<Name>        - 13px, used for fluent:Button.Icon (small slot)
        Calcite.<Name>.Large  - 22px, used for fluent:Button.LargeIcon (large slot)
    Both wrap the geometry in a Viewbox with explicit Width/Height so the glyph
    renders at a fixed pixel size and never grows to fill its container.

    x:Shared="False" so the same key can be referenced by multiple buttons.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Raw 16x16 geometry data, shared by both size variants. -->
    <Geometry x:Key="Calcite.Geom.Play">M4 1.571V14.43L14 8zm1 1.832l7.15 4.598L5 12.597z</Geometry>
    <Geometry x:Key="Calcite.Geom.X">M3.98 11.303L7.281 8 3.98 4.697l.707-.707L7.99 7.293l.01-.01.01.01 3.304-3.303.707.707L8.718 8l3.303 3.303-.707.707L8.01 8.707l-.01.01-.01-.01-3.304 3.303z</Geometry>
    <Geometry x:Key="Calcite.Geom.Check">M6.5 12.25L2.25 8l.707-.707L6.5 10.836l6.543-6.543.707.707z</Geometry>
