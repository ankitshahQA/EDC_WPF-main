    <Geometry x:Key="Calcite.Geom.Dashboard">M12.425 13.718a6.43 6.43 0 0 0 1.24-6.262l.78-.78a7.477 7.477 0 0 1-2.008 8.46l-2.109-2.1.708-.708zm2.726-9.162L8.85 10.857a1.514 1.514 0 1 1-.707-.707l6.301-6.301zM8 11.5a.5.5 0 1 0-.5.5.5.5 0 0 0 .5-.5zM7 5h1V3.025a6.478 6.478 0 0 1 4.03 1.823l.71-.71a7.495 7.495 0 1 0-10.177 11l2.109-2.101-.708-.708-1.389 1.39A6.45 6.45 0 0 1 1.028 10H3V9H1.025A6.466 6.466 0 0 1 2.57 5.276l1.395 1.396.708-.708L3.276 4.57A6.465 6.465 0 0 1 7 3.025z</Geometry>
    <Geometry x:Key="Calcite.Geom.ChevronRight">M5.5 13.5L11 8 5.5 2.5l.707-.707L12.414 8l-6.207 6.207z</Geometry>

    <!--
        Small (16px) variants - bind to fluent:Button.Icon.
        Explicit Width/Height keep the glyph compact in the small icon slot.
    -->
    <Viewbox x:Key="Calcite.Play"        x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Play}"        Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.X"           x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.X}"           Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.Save"        x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Save}"        Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.Refresh"     x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Refresh}"     Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.File"        x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.File}"        Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.FileReport"  x:Shared="False" Width="14" Height="14" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.FileReport}"  Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.FolderOpen"  x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.FolderOpen}"  Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.Trash"       x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Trash}"       Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.Moon"        x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Moon}"        Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.Information" x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Information}" Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.Reset"       x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Reset}"       Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.Grid"        x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Grid}"        Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.Dashboard"   x:Shared="False" Width="16" Height="16" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Dashboard}"   Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>

    <!--
        Large (22px) variants - bind to fluent:Button.LargeIcon.
        Used by the four Large-sized ribbon buttons: Run Tests, Stop, Open Report, About.
    -->
    <Viewbox x:Key="Calcite.Play.Large"        x:Shared="False" Width="22" Height="22" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Play}"        Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.X.Large"           x:Shared="False" Width="22" Height="22" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.X}"           Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.FileReport.Large"  x:Shared="False" Width="22" Height="22" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.FileReport}"  Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>
    <Viewbox x:Key="Calcite.Information.Large" x:Shared="False" Width="22" Height="22" Stretch="Uniform"><Path Data="{StaticResource Calcite.Geom.Information}" Fill="{DynamicResource TextPrimaryBrush}"/></Viewbox>

</ResourceDictionary>
