    <Geometry x:Key="Calcite.Geom.Refresh">M1.282 7H.272A7.788 7.788 0 0 1 15 4.582V2h1v4h-4V5h2.093a6.788 6.788 0 0 0-12.81 2zM1 11.418A7.788 7.788 0 0 0 15.728 9h-1.01a6.788 6.788 0 0 1-12.811 2H4v-1H0v4h1z</Geometry>
    <Geometry x:Key="Calcite.Geom.File">M15 3.6L11.4 0H2v16h13zM14 15H3V1h7v4h4zm0-11h-3V1h.31L14 3.69z</Geometry>
    <Geometry x:Key="Calcite.Geom.FileReport">M15 3.6L11.4 0H2v16h13zM14 15H3V1h7v4h4zm0-11h-3V1h.31L14 3.69zM4 14h9V7H4zm3-1v-1h2v1zm0-2v-1h2v1zm5 2h-2v-1h2zm0-2h-2v-1h2zm0-3v1h-2V8zM9 8v1H7V8zM5 8h1v1H5zm0 2h1v1H5zm0 2h1v1H5zm4-9H4V2h5zm0 2H4V4h5z</Geometry>
    <Geometry x:Key="Calcite.Geom.FolderOpen">M8.3 3.002L6.98 2H4L2.7 3H1v11h13l2-8h-2V3zM2 4h1.041L4.34 3h2.304l1.319 1.002L13 4v2H9L7.7 7h-4L2 11.408zm12.719 3l-1.5 6H2.458l1.929-5H8.04l1.3-1z</Geometry>
    <Geometry x:Key="Calcite.Geom.Trash">M12.854 4h1.003l-.79 11.071a1.004 1.004 0 0 1-.999.929H3.932a1.004 1.004 0 0 1-.998-.93L2.143 4h1.003l.786 11h8.136zm-9.78-1H1V2h4V1a1.001 1.001 0 0 1 1-1h4a1.001 1.001 0 0 1 1 1v1h4v1H3.074zM6 2h4V1H6zm3.5 11a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-1 0v7a.5.5 0 0 0 .5.5zm-3 0a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-1 0v7a.5.5 0 0 0 .5.5z</Geometry>
