{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run EDC.Wpf (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build EDC.Wpf",
            "program": "${workspaceFolder}/EDC.Wpf.Solution/EDC.Wpf/bin/Debug/net8.0-windows/Enterprise Deployment Check.exe",
            "args": [],
            "cwd": "${workspaceFolder}/EDC.Wpf.Solution/EDC.Wpf/bin/Debug/net8.0-windows",
            "console": "internalConsole",
            "stopAtEntry": false,
            "requireExactSource": false
        },
        {
            "name": "Attach to running EDC",
            "type": "coreclr",
            "request": "attach",
            "processName": "Enterprise Deployment Check"
        }
    ]
}
