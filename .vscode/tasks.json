{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build EDC.Wpf",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/EDC.Wpf.Solution/EDC.sln",
                "-c", "Debug",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "test EDC.Wpf.Tests",
            "type": "process",
            "command": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/EDC.Wpf.Solution/EDC.Wpf.Tests/EDC.Wpf.Tests.csproj",
                "--nologo"
            ],
            "group": "test",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish single-file EDC.exe (Release)",
            "type": "process",
            "command": "dotnet",
            "args": [
                "publish",
                "${workspaceFolder}/EDC.Wpf.Solution/EDC.Wpf/EDC.Wpf.csproj",
                "-c", "Release",
                "-r", "win-x64",
                "--self-contained", "true",
                "-p:PublishSingleFile=true",
                "-p:IncludeNativeLibrariesForSelfExtract=true",
                "-p:EnableCompressionInSingleFile=true",
                "--nologo"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
